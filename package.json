{
  "name": "orbion",
  "version": "0.1.0",
  "description": "Orbion — the open-source control plane for Loop Engineering. Manages loop-task environments (loops, logs, projects) over the loop-task HTTP API.",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Quique Fdez Guerra",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
