{
  "name": "orbion",
  "version": "0.1.0",
  "description": "Orbion — the open-source control plane for Loop Engineering. Manages loop-task environments (loops, logs, projects) over the loop-task HTTP API.",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Quique Fdez Guerra",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.18",
    "@tanstack/react-virtual": "^3.14.5",
    "electron-store": "^11.0.2",
    "highlight.js": "^11.11.1",
    "inversify-hooks": "^4.0.0",
    "lucide-react": "^0.469.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-intl": "^10.1.16",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
