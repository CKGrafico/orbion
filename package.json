    "electron": "^37.10.3",
    "electron-vite": "^4.0.0",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
