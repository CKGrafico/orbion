    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-intl": "^10.1.16",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rehype-highlight": "^7.0.2",
